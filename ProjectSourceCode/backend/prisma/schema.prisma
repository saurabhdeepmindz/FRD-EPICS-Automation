// Prisma schema for PRD Generator
// Provider: postgresql
// Run: npx prisma db push  (dev)
//      npx prisma migrate dev --name <name>  (migration)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum PrdStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  BASELINED
}

enum SectionStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
}

// ─── PRD document (one row per PRD) ──────────────────────────────────────────

model Prd {
  id          String    @id @default(cuid())
  prdCode     String    @unique         // e.g. PRD-LSM001
  productName String
  version     String    @default("1.0")
  status      PrdStatus @default(DRAFT)
  author      String?
  clientName  String?
  submittedBy String?
  clientLogo  String?           // base64 data-URI or file path
  sourceText  String?   @db.Text  // original input text used to generate PRD
  sourceFileName String?          // original uploaded file name (if any)
  sourceFileData String? @db.Text // original file stored as base64 (Phase 1: local DB, Phase 2: S3 URL)
  reviewedBy  String?
  approvedBy  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  sections    PrdSection[]
  auditLogs   PrdAuditLog[]

  @@map("prds")
}

// ─── PRD section (one row per section per PRD) ────────────────────────────────

model PrdSection {
  id            String        @id @default(cuid())
  prdId         String
  sectionNumber Int           // 1–22
  sectionName   String
  status        SectionStatus @default(NOT_STARTED)
  content       Json          @default("{}")  // flexible JSON per section schema
  aiSuggested   Boolean       @default(false) // true if any field was AI-filled
  completedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  prd           Prd           @relation(fields: [prdId], references: [id], onDelete: Cascade)

  @@unique([prdId, sectionNumber])
  @@map("prd_sections")
}

// ─── Audit trail (one row per field change) ───────────────────────────────

enum ChangeType {
  CREATED
  MODIFIED
  AI_GENERATED
  AI_MODIFIED
}

enum ChangeSource {
  AI
  MANUAL
}

model PrdAuditLog {
  id            String       @id @default(cuid())
  prdId         String
  sectionNumber Int
  fieldKey      String       // e.g. "productName", "6.1_features[0].description"
  changeType    ChangeType
  source        ChangeSource
  previousValue String?      @db.Text
  newValue      String?      @db.Text
  version       String       // e.g. "1.0", "1.1"
  createdAt     DateTime     @default(now())

  prd           Prd          @relation(fields: [prdId], references: [id], onDelete: Cascade)

  @@index([prdId, createdAt])
  @@map("prd_audit_logs")
}

// ═══════════════════════════════════════════════════════════════════════════════
// BA AUTOMATION TOOL — New models (additive only — existing models untouched)
// ═══════════════════════════════════════════════════════════════════════════════

// ─── BA Project ──────────────────────────────────────────────────────────────

enum BaProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

model BaProject {
  id          String          @id @default(uuid())
  name        String
  projectCode String          @unique
  description String?
  productName String?         // Required before EPIC generation
  clientName  String?
  submittedBy String?
  clientLogo  String?         @db.Text   // base64 data-URI for preview cover
  status      BaProjectStatus @default(ACTIVE)
  // Project-wide SQL dialect used by skills that emit SQL (FTC test data,
  // verification scripts). Values: "postgresql" | "mysql" | "sqlserver" |
  // "oracle" | "ansi". Default Postgres matches the app's own DB.
  sqlDialect  String          @default("postgresql")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  modules     BaModule[]
  rtmRows     BaRtmRow[]
  masterDataEntries BaMasterDataEntry[]
  templates   BaTemplate[]

  @@map("ba_projects")
}

// ─── BA Module ───────────────────────────────────────────────────────────────

enum BaModuleStatus {
  DRAFT
  SCREENS_UPLOADED
  ANALYSIS_COMPLETE
  FRD_COMPLETE
  EPICS_COMPLETE
  STORIES_COMPLETE
  SUBTASKS_COMPLETE
  APPROVED
}

model BaModule {
  id              String         @id @default(uuid())
  projectId       String
  project         BaProject      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  moduleId        String         // e.g. MOD-01
  moduleName      String
  packageName     String
  moduleStatus    BaModuleStatus @default(DRAFT)
  processedAt     DateTime?
  approvedAt      DateTime?
  // v4 — LLD completion tracked independently of the existing status machine
  lldCompletedAt  DateTime?
  lldArtifactId   String?
  // v4.2 — FTC (Functional Test Cases) completion, same independence as LLD
  ftcCompletedAt  DateTime?
  ftcArtifactId   String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  screens          BaScreen[]
  flows            BaClickThroughFlow[]
  skillExecutions  BaSkillExecution[]
  artifacts        BaArtifact[]
  tbdFutureEntries BaTbdFutureEntry[]
  subtasks         BaSubTask[]
  lldConfig        BaLldConfig?
  ftcConfig        BaFtcConfig?

  @@unique([projectId, moduleId])
  @@map("ba_modules")
}

// ─── BA Screen ───────────────────────────────────────────────────────────────

model BaScreen {
  id                  String   @id @default(uuid())
  moduleDbId          String
  module              BaModule @relation(fields: [moduleDbId], references: [id], onDelete: Cascade)
  screenId            String   // e.g. SCR-01
  screenTitle         String
  screenType          String?  // Dashboard / Form / List / Detail / Modal / Navigation / Other
  fileData            String   @db.Text // base64 image data (Phase 1: DB, Phase 2: S3 URL)
  fileName            String   // original file name
  mimeType            String   // image/png, image/jpeg, etc.
  displayOrder        Int      @default(0)
  textDescription     String?  @db.Text
  audioFileData       String?  @db.Text // base64 audio (Phase 1)
  audioTranscript     String?  @db.Text
  transcriptReviewed  Boolean  @default(false)
  aiFormattedTranscript String? @db.Text  // AI-polished version of transcript
  aiTranscriptReviewed  Boolean @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([moduleDbId, screenId])
  @@map("ba_screens")
}

// ─── BA Click-Through Flow ───────────────────────────────────────────────────

model BaClickThroughFlow {
  id          String   @id @default(uuid())
  moduleDbId  String
  module      BaModule @relation(fields: [moduleDbId], references: [id], onDelete: Cascade)
  flowName    String
  steps       Json     // Array of { screenId, triggerLabel, outcome }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ba_click_through_flows")
}

// ─── BA Skill Execution ──────────────────────────────────────────────────────

enum BaExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  AWAITING_REVIEW
  APPROVED
  FAILED
}

model BaSkillExecution {
  id              String            @id @default(uuid())
  moduleDbId      String
  module          BaModule          @relation(fields: [moduleDbId], references: [id], onDelete: Cascade)
  skillName       String            // SKILL-00, SKILL-01-S, SKILL-02-S, SKILL-04, SKILL-05
  status          BaExecutionStatus @default(PENDING)
  contextPacket   Json?             // assembled context sent to AI
  rawOutput       String?           @db.Text
  humanDocument   String?           @db.Text  // markdown output
  handoffPacket   Json?             // compressed JSON for next skill
  errorMessage    String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime          @default(now())

  @@index([moduleDbId, skillName])
  @@map("ba_skill_executions")
}

// ─── BA Artifact ─────────────────────────────────────────────────────────────

enum BaArtifactType {
  SCREEN_ANALYSIS
  FRD
  EPIC
  USER_STORY
  SUBTASK
  PRD
  RTM
  LLD
  FTC
}

enum BaArtifactStatus {
  DRAFT
  CONFIRMED_PARTIAL
  CONFIRMED
  APPROVED
}

model BaArtifact {
  id           String           @id @default(uuid())
  moduleDbId   String
  module       BaModule         @relation(fields: [moduleDbId], references: [id], onDelete: Cascade)
  artifactType BaArtifactType
  artifactId   String           // e.g. FRD-MOD-02, EPIC-02, US-013
  status       BaArtifactStatus @default(DRAFT)
  approvedAt   DateTime?
  // Snapshot of architect narrative used to produce this artifact (LLD only).
  // Populated when the LLD was generated via the narrative flow; null for
  // stack-only generations so existing queries are unaffected.
  sourceNarrative String?        @db.Text
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  sections     BaArtifactSection[]
  subtasks     BaSubTask[]
  pseudoFiles  BaPseudoFile[]
  testCases    BaTestCase[]

  @@map("ba_artifacts")
}

model BaArtifactSection {
  id              String     @id @default(uuid())
  artifactId      String
  artifact        BaArtifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  sectionKey      String     // e.g. "businessContext", "integrationDomains"
  sectionLabel    String     // human-readable label
  aiGenerated     Boolean    @default(true)
  content         String     @db.Text
  editedContent   String?    @db.Text  // human-edited version
  isHumanModified Boolean    @default(false)
  isLocked        Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@map("ba_artifact_sections")
}

// ─── BA TBD-Future Registry ──────────────────────────────────────────────────

model BaTbdFutureEntry {
  id                 String   @id @default(uuid())
  moduleDbId         String
  module             BaModule @relation(fields: [moduleDbId], references: [id], onDelete: Cascade)
  registryId         String   // e.g. TBD-001
  integrationName    String
  classification     String   // INTERNAL-TBD-Future or EXTERNAL-TBD-Future
  referencedModule   String?  // MOD-XX
  assumedInterface   String   @db.Text
  resolutionTrigger  String
  appearsInFeatures  String[] // Array of Feature IDs
  isResolved         Boolean  @default(false)
  resolvedAt         DateTime?
  resolvedInterface  String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("ba_tbd_future_entries")
}

// ─── BA RTM Row ──────────────────────────────────────────────────────────────

model BaRtmRow {
  id                String    @id @default(uuid())
  projectId         String
  project           BaProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  moduleId          String    // MOD-XX
  moduleName        String
  packageName       String
  featureId         String
  featureName       String
  featureStatus     String
  priority          String
  screenRef         String
  epicId            String?
  epicName          String?
  storyId           String?
  storyName         String?
  storyType         String?   // Frontend / Backend / Integration
  storyStatus       String?
  primaryClass      String?
  sourceFile        String?
  subtaskId         String?
  subtaskTeam       String?   // FE / BE / IN / QA
  methodName        String?
  testCaseIds       String[]
  integrationStatus String?
  tbdFutureRef      String?
  tbdResolved       Boolean   @default(false)
  // LLD trace — populated after SKILL-06-LLD. Links the RTM row to pseudo-code files
  // derived from SKILL-06 so the trace runs all the way to source.
  lldArtifactId     String?   // ba_artifacts.id of the active LLD bundle
  layer             String?   // Frontend / Backend / Database / Integration / Testing
  pseudoFileIds     String[]  @default([])
  pseudoFilePaths   String[]  @default([])
  // FTC trace — populated after SKILL-07-FTC. testCaseIds already existed for
  // pre-FTC SubTask test-case references; new columns below track the FTC
  // artifact + OWASP coverage per RTM row.
  ftcArtifactId     String?   // ba_artifacts.id of the active FTC bundle
  ftcTestCaseIds    String[]  @default([])  // BaTestCase.id values
  ftcTestCaseRefs   String[]  @default([])  // human-readable TC-001, TC-002-INT-01, ...
  owaspWebCategories String[] @default([])  // A01, A03, ...
  owaspLlmCategories String[] @default([])  // LLM01, LLM06, ...
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([projectId, moduleId])
  @@map("ba_rtm_rows")
}

// ─── BA SubTask (structured output from SKILL-05) ────────────────────────────

enum SubTaskStatus {
  DRAFT
  APPROVED
  IMPLEMENTED
}

model BaSubTask {
  id               String        @id @default(uuid())
  moduleDbId       String
  module           BaModule      @relation(fields: [moduleDbId], references: [id], onDelete: Cascade)
  artifactDbId     String?
  artifact         BaArtifact?   @relation(fields: [artifactDbId], references: [id])
  subtaskId        String        // e.g. ST-US001-BE-01
  subtaskName      String
  subtaskType      String?       // Code / Config / Test / Documentation / DevOps
  team             String?       // FE / BE / IN / QA
  userStoryId      String?       // e.g. US-001
  epicId           String?       // e.g. EPIC-01
  featureId        String?       // e.g. F-01-01
  moduleId         String?       // e.g. MOD-01
  packageName      String?
  assignedTo       String?
  estimatedEffort  String?       // e.g. "4 hours"
  prerequisites    String[]      // SubTask IDs this depends on
  status           SubTaskStatus @default(DRAFT)
  priority         String?       // P0 / P1 / P2 / P3
  tbdFutureRefs    String[]      // e.g. ["TBD-001"]
  sourceFileName   String?
  className        String?
  methodName       String?
  approvedAt       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  sections         BaSubTaskSection[]

  @@unique([moduleDbId, subtaskId])
  @@index([moduleDbId])
  @@map("ba_subtasks")
}

model BaSubTaskSection {
  id              String     @id @default(uuid())
  subtaskDbId     String
  subtask         BaSubTask  @relation(fields: [subtaskDbId], references: [id], onDelete: Cascade)
  sectionNumber   Int        // 1-24
  sectionKey      String     // e.g. "algorithm", "integration_points"
  sectionLabel    String     // e.g. "Algorithm", "Integration Points"
  aiContent       String     @db.Text   // original AI output — immutable
  editedContent   String?    @db.Text   // human-edited version
  isHumanModified Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([subtaskDbId, sectionNumber])
  @@map("ba_subtask_sections")
}

// ─── v4: Architect Console (Master Data) ─────────────────────────────────────

enum BaMasterDataCategory {
  FRONTEND_STACK
  BACKEND_STACK
  DATABASE
  STREAMING
  CACHING
  STORAGE
  CLOUD
  ARCHITECTURE
  PROJECT_STRUCTURE
  BACKEND_TEMPLATE
  FRONTEND_TEMPLATE
  LLD_TEMPLATE
  FTC_TEMPLATE
  CODING_GUIDELINES
}

enum BaMasterDataScope {
  GLOBAL
  PROJECT
}

enum BaTemplateModifier {
  AI
  HUMAN
}

model BaMasterDataEntry {
  id          String               @id @default(uuid())
  category    BaMasterDataCategory
  scope       BaMasterDataScope    @default(PROJECT)
  projectId   String?
  project     BaProject?           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  value       String
  description String?              @db.Text
  templateId  String?
  template    BaTemplate?          @relation(fields: [templateId], references: [id])
  isArchived  Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@unique([category, scope, projectId, name])
  @@index([category, scope])
  @@map("ba_master_data_entries")
}

model BaTemplate {
  id               String              @id @default(uuid())
  category         BaMasterDataCategory
  name             String
  version          Int                 @default(1)
  parentTemplateId String?
  parent           BaTemplate?         @relation("TemplateLineage", fields: [parentTemplateId], references: [id])
  children         BaTemplate[]        @relation("TemplateLineage")
  lastModifiedBy   BaTemplateModifier  @default(HUMAN)
  scope            BaMasterDataScope   @default(PROJECT)
  projectId        String?
  project          BaProject?          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  content          String              @db.Text
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  masterDataEntries BaMasterDataEntry[]

  @@index([category, scope])
  @@map("ba_templates")
}

// ─── v4: LLD Configuration + Pseudo-code files ───────────────────────────────

model BaLldConfig {
  id                 String    @id @default(uuid())
  moduleDbId         String    @unique
  module             BaModule  @relation(fields: [moduleDbId], references: [id], onDelete: Cascade)
  // Tech stack single-select FKs (null = skip, use AI best practices)
  frontendStackId    String?
  backendStackId     String?
  databaseId         String?
  streamingId        String?
  cachingId          String?
  storageId          String?
  cloudId            String?
  architectureId     String?
  cloudServices      String?   @db.Text
  // Template single-select FKs (null until Architect uploads)
  projectStructureId String?
  backendTemplateId  String?
  frontendTemplateId String?
  lldTemplateId      String?
  codingGuidelinesId String?
  // NFR values + free-form notes
  nfrValues          Json?
  customNotes        String?   @db.Text
  // Narrative-driven LLD (additive — null = use existing stack/template-only flow)
  narrative          String?   @db.Text
  useAsAdditional    Boolean   @default(true)
  attachments        BaLldConfigAttachment[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("ba_lld_configs")
}

// Architect attachments supplied alongside narrative. File bytes live on the
// configured storage backend (disk by default, S3/GCS via env). Only metadata
// + the extracted text live in Postgres.
model BaLldConfigAttachment {
  id              String       @id @default(uuid())
  lldConfigId     String
  lldConfig       BaLldConfig  @relation(fields: [lldConfigId], references: [id], onDelete: Cascade)
  fileName        String
  mimeType        String
  sizeBytes       Int
  storageBackend  String       // "disk" | "s3" | "gcs"
  storageKey      String       // path/key within the backend
  extractedText   String?      @db.Text
  extractionNote  String?      // why extraction failed, if applicable
  createdAt       DateTime     @default(now())

  @@index([lldConfigId])
  @@map("ba_lld_config_attachments")
}

model BaPseudoFile {
  id              String     @id @default(uuid())
  artifactDbId    String
  artifact        BaArtifact @relation(fields: [artifactDbId], references: [id], onDelete: Cascade)
  path            String
  language        String
  aiContent       String     @db.Text
  editedContent   String?    @db.Text
  isHumanModified Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([artifactDbId, path])
  @@index([artifactDbId])
  @@map("ba_pseudo_files")
}

// ─── v4.2: FTC Configuration + Test Cases + Attachments ─────────────────────

model BaFtcConfig {
  id                   String    @id @default(uuid())
  moduleDbId           String    @unique
  module               BaModule  @relation(fields: [moduleDbId], references: [id], onDelete: Cascade)
  // Test framework — multi-select. Architect can pick several and the skill
  // routes per-TC hints by category (UI→Playwright/Cypress, backend→pytest/JUnit,
  // perf→k6/JMeter, integration→REST-assured/Postman, etc.).
  testingFrameworks    String[]  @default([])
  // Coverage depth — single value. Smoke ⊂ Regression ⊂ Full.
  coverageTarget       String?   // Smoke | Regression | Full
  // Test types — multi-select. Filters which TC categories the skill emits.
  // Empty array = fall back to "all types" (matches pre-multiselect behaviour).
  testTypes            String[]  @default([])
  // OWASP preferences (MVP: Web Top 10 + LLM Top 10)
  owaspWebEnabled      Boolean   @default(true)
  owaspLlmEnabled      Boolean   @default(true)
  excludedOwaspWeb     String[]  @default([])  // e.g. ["A10"]
  excludedOwaspLlm     String[]  @default([])  // e.g. ["LLM08"]
  // When true and an LLD artifact exists for the module, generate white-box TCs
  includeLldReferences Boolean   @default(true)
  // FTC template — optional uploaded structural template (master data entry id)
  ftcTemplateId        String?
  // Free-form tester/architect notes (beyond the narrative field)
  customNotes          String?   @db.Text
  // Narrative-driven FTC (mirrors LLD narrative flow — additive)
  narrative            String?   @db.Text
  useAsAdditional      Boolean   @default(true)
  attachments          BaFtcConfigAttachment[]
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@map("ba_ftc_configs")
}

model BaFtcConfigAttachment {
  id              String       @id @default(uuid())
  ftcConfigId     String
  ftcConfig       BaFtcConfig  @relation(fields: [ftcConfigId], references: [id], onDelete: Cascade)
  fileName        String
  mimeType        String
  sizeBytes       Int
  storageBackend  String
  storageKey      String
  extractedText   String?      @db.Text
  extractionNote  String?
  createdAt       DateTime     @default(now())

  @@index([ftcConfigId])
  @@map("ba_ftc_config_attachments")
}

// Individual functional test case produced by SKILL-07-FTC. Parallel to
// BaPseudoFile but with structured fields suited to FTC: steps, expected,
// SQL setup/verify, OWASP tags, integration flag, playwright hints, and
// many-to-many traceability to features / stories / subtasks / pseudo files.
model BaTestCase {
  id                   String     @id @default(uuid())
  artifactDbId         String
  artifact             BaArtifact @relation(fields: [artifactDbId], references: [id], onDelete: Cascade)
  testCaseId           String     // human-readable: TC-001, Neg_TC-005, TC-001-INT-01
  title                String
  category             String?    // Functional | Integration | Security | Data | UI | Performance | ...
  scope                String     @default("black_box") // black_box | white_box
  testKind             String     @default("positive")  // positive | negative | edge
  priority             String?    // P0 | P1 | P2
  // Sprint & execution tracking — sprintId + executionStatus populated in v2;
  // schema columns reserved now so CSV export + future UI don't need another migration.
  sprintId             String?
  executionStatus      String     @default("NOT_RUN") // NOT_RUN | PASS | FAIL | BLOCKED | SKIPPED
  lastRunAt            DateTime?
  lastRunBy            String?
  defectIds            String[]   @default([]) // JIRA / Linear / GitHub issue refs
  // Scenario grouping (matches the CSV "Signup (Starter) Positive Tc" / "Negative Tc" pattern)
  scenarioGroup        String?    // e.g. "Signup – Starter Plan"
  testData             String?    @db.Text // concrete inputs: emails, phone numbers, card details, …
  e2eFlow              String?    // arrow-summary: "Launch URL → Signup → Submit → Success"
  preconditions        String?    @db.Text
  steps                String     @db.Text // markdown-formatted numbered steps
  expected             String     @db.Text // step-level expected outcome
  postValidation       String?    @db.Text // cross-cutting post-checks (email received, audit row, DB state)
  supportingDocs       String[]   @default([]) // screenshot / doc / trace names referenced by the TC
  // SQL helpers. Dialect comes from BaProject.sqlDialect.
  sqlSetup             String?    @db.Text // run before the test (insert fixtures, create tenant, …)
  sqlVerify            String?    @db.Text // run after the test (assert row state, audit entries, …)
  // Integration sub-test flag — these carry a parent testCaseId like TC-001
  isIntegrationTest    Boolean    @default(false)
  parentTestCaseId     String?    // the parent TC this integration case belongs to
  // OWASP tags (web A01-A10 or LLM LLM01-LLM10, null when not applicable)
  owaspCategory        String?
  // Playwright automation hints (selectors + actions + assertions). Plain text
  // for MVP; v2 may render these into runnable .spec.ts.
  playwrightHint       String?    @db.Text
  // Hints for the future v5.1 TDD codegen skill (what unit-level assertions
  // this functional case implies). Plain text; codegen parses later.
  developerHints       String?    @db.Text
  // Many-to-many traceability via opaque id arrays. IDs come from BaArtifact
  // parse time (FRD feature ids, EPIC ids, story ids, subtask ids, pseudo file ids).
  linkedFeatureIds     String[]   @default([])
  linkedEpicIds        String[]   @default([])
  linkedStoryIds       String[]   @default([])
  linkedSubtaskIds     String[]   @default([])
  linkedPseudoFileIds  String[]   @default([])
  linkedLldArtifactId  String?    // when the TC is white-box, which LLD it references
  tags                 String[]   @default([])
  // Raw AI output for this TC (before any human edits), and the edited copy
  aiContent            String     @db.Text
  editedContent        String?    @db.Text
  isHumanModified      Boolean    @default(false)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  @@unique([artifactDbId, testCaseId])
  @@index([artifactDbId])
  @@index([parentTestCaseId])
  @@map("ba_test_cases")
}
